{
  "manifest_version": 3,
  "name": "Lookout Admin Feature Flags",
  "version": "1.0.0",
  "description": "Format and display feature flags for tenants in the Lookout admin console",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.lookout.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.lookout.com/les/api/public/v1/console/cache*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lookout Feature Flags"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
